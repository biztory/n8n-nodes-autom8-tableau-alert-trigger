{
    "name": "n8n-nodes-autom8-tableau-alert-trigger",
    "version": "0.5.4",
    "description": "Autom8 Tableau Alert Trigger node for n8n. Polls a Tableau view or datasource on a schedule and fires when a configured condition is met.",
    "license": "MIT",
    "homepage": "https://autom8.biztory.com",
    "keywords": [
        "n8n-community-node-package",
        "tableau",
        "autom8",
        "trigger",
        "polling",
        "data alert"
    ],
    "author": {
        "name": "Timothy Vermeiren (Biztory)",
        "email": "timothy.vermeiren@biztory.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/biztory/n8n-nodes-autom8-tableau-alert-trigger.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/Autom8TableauConnectedAppApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Autom8TableauAlertTrigger/Autom8TableauAlertTrigger.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
